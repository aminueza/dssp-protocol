{
  "description": "Three-event Merkle chain test vector demonstrating hash chaining",
  "spec_reference": "DSP v0.1, §3.3.4",
  "algorithm": "sha-256",
  "notes": "Each event's hash is computed over the RFC 8785 canonical JSON of the event (excluding the event_hash field). The previous_event_hash field links each event to the prior one, forming an immutable chain. Implementations should verify: (1) each event_hash matches the SHA-256 of its canonical form, and (2) each previous_event_hash matches the event_hash of the preceding event.",
  "chain": [
    {
      "event_index": 0,
      "description": "Genesis event — no previous_event_hash",
      "event": {
        "dsp_version": "0.1",
        "event_id": "ev-0000000000000001",
        "sequence_number": 0,
        "timestamp": "2026-02-15T10:00:00Z",
        "event_type": "ledger.genesis",
        "actor": {"type": "system"},
        "subject": {"type": "ledger"},
        "outcome": {"status": "success"}
      },
      "canonical_form": "{\"actor\":{\"type\":\"system\"},\"dsp_version\":\"0.1\",\"event_id\":\"ev-0000000000000001\",\"event_type\":\"ledger.genesis\",\"outcome\":{\"status\":\"success\"},\"sequence_number\":0,\"subject\":{\"type\":\"ledger\"},\"timestamp\":\"2026-02-15T10:00:00Z\"}",
      "expected_event_hash": "sha-256:c9cb28f13e6ef09cf5faebaa24de5dc11ca7c39fdf934952dfacbdf94a370935"
    },
    {
      "event_index": 1,
      "description": "Session started — chains to genesis event",
      "event": {
        "dsp_version": "0.1",
        "event_id": "ev-0000000000000002",
        "previous_event_hash": {"algorithm": "sha-256", "value": "c9cb28f13e6ef09cf5faebaa24de5dc11ca7c39fdf934952dfacbdf94a370935"},
        "sequence_number": 1,
        "timestamp": "2026-02-15T10:30:00Z",
        "event_type": "session.started",
        "actor": {"type": "agent", "org_id": "org-docuverify", "agent_id": "ag-dv-extractor-v4"},
        "subject": {"type": "session", "session_id": "ps-abc123"},
        "action": {"contract_id": "ct-def456"},
        "outcome": {"status": "success"}
      },
      "canonical_form": "{\"action\":{\"contract_id\":\"ct-def456\"},\"actor\":{\"agent_id\":\"ag-dv-extractor-v4\",\"org_id\":\"org-docuverify\",\"type\":\"agent\"},\"dsp_version\":\"0.1\",\"event_id\":\"ev-0000000000000002\",\"event_type\":\"session.started\",\"outcome\":{\"status\":\"success\"},\"previous_event_hash\":{\"algorithm\":\"sha-256\",\"value\":\"c9cb28f13e6ef09cf5faebaa24de5dc11ca7c39fdf934952dfacbdf94a370935\"},\"sequence_number\":1,\"subject\":{\"session_id\":\"ps-abc123\",\"type\":\"session\"},\"timestamp\":\"2026-02-15T10:30:00Z\"}",
      "expected_event_hash": "sha-256:4f066f73ef9039457c0c81d610fed1084a1386373fdd6aff52436328cfc387ea"
    },
    {
      "event_index": 2,
      "description": "Data accessed — chains to session started event",
      "event": {
        "dsp_version": "0.1",
        "event_id": "ev-0000000000000003",
        "previous_event_hash": {"algorithm": "sha-256", "value": "4f066f73ef9039457c0c81d610fed1084a1386373fdd6aff52436328cfc387ea"},
        "sequence_number": 2,
        "timestamp": "2026-02-15T10:30:05Z",
        "event_type": "document.accessed",
        "actor": {"type": "agent", "org_id": "org-docuverify", "agent_id": "ag-dv-extractor-v4"},
        "subject": {"type": "document", "document_id": "doc-inv-2026-001"},
        "action": {"operation": "read", "fields_accessed": ["invoice_number", "amount", "date"]},
        "outcome": {"status": "success"}
      },
      "canonical_form": "{\"action\":{\"fields_accessed\":[\"invoice_number\",\"amount\",\"date\"],\"operation\":\"read\"},\"actor\":{\"agent_id\":\"ag-dv-extractor-v4\",\"org_id\":\"org-docuverify\",\"type\":\"agent\"},\"dsp_version\":\"0.1\",\"event_id\":\"ev-0000000000000003\",\"event_type\":\"document.accessed\",\"outcome\":{\"status\":\"success\"},\"previous_event_hash\":{\"algorithm\":\"sha-256\",\"value\":\"4f066f73ef9039457c0c81d610fed1084a1386373fdd6aff52436328cfc387ea\"},\"sequence_number\":2,\"subject\":{\"document_id\":\"doc-inv-2026-001\",\"type\":\"document\"},\"timestamp\":\"2026-02-15T10:30:05Z\"}",
      "expected_event_hash": "sha-256:5c64056d0b32d881e5a768b6ad826e22163ef1fb55ef5d017af9f033125a6c69"
    }
  ],
  "verification_steps": [
    "1. For each event, serialize the event object (without event_hash) to RFC 8785 canonical JSON",
    "2. Compute SHA-256 of the canonical JSON bytes",
    "3. Verify the computed hash matches expected_event_hash",
    "4. For events at index > 0, verify that previous_event_hash.value matches the expected_event_hash of the preceding event",
    "5. Verify sequence_numbers are strictly incrementing starting from 0",
    "6. Verify timestamps are non-decreasing"
  ]
}
